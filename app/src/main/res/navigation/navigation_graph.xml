<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_graph"
    app:startDestination="@id/mediatekaFragment">
    <fragment
        android:id="@+id/mediatekaFragment"
        android:name="com.example.playlistmaker.mvvm.media.ui.MediatekaFragment"
        android:label="fragment_mediateka"
        tools:layout="@layout/fragment_mediateka" >
        <action
            android:id="@+id/action_mediatekaFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_mediatekaFragment_to_fragmentNewPlaylist"
            app:destination="@id/fragmentNewPlaylist" />
        <action
            android:id="@+id/action_mediatekaFragment_to_fragmentPlaylistScreen"
            app:destination="@id/fragmentPlaylistScreen" />
    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.playlistmaker.mvvm.search.ui.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_playerFragment"
            app:destination="@id/playerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.playlistmaker.mvvm.settings.ui.SettingsFragment"
        android:label="fragment_settings"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/playerFragment"
        android:name="com.example.playlistmaker.mvvm.player.ui.PlayerFragment"
        android:label="fragment_player"
        tools:layout="@layout/fragment_player" >
        <action
            android:id="@+id/action_playerFragment_to_fragmentNewPlaylist"
            app:destination="@id/fragmentNewPlaylist" />
    </fragment>
    <fragment
        android:id="@+id/fragmentNewPlaylist"
        android:name="com.example.playlistmaker.mvvm.media.ui.createPlaylist.FragmentCreatePlaylist"
        android:label="fragment_new_playlist"
        tools:layout="@layout/fragment_create_playlist" />
    <fragment
        android:id="@+id/fragmentPlaylistScreen"
        android:name="com.example.playlistmaker.mvvm.media.ui.playlistScreen.FragmentPlaylistScreen"
        android:label="fragment_playlist_screen"
        tools:layout="@layout/fragment_playlist_screen" >
        <action
            android:id="@+id/action_fragmentPlaylistScreen_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_fragmentPlaylistScreen_to_fragmentNewPlaylist"
            app:destination="@id/fragmentNewPlaylist" />
    </fragment>
</navigation>