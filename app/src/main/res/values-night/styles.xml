<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="colorSearchField" parent="searchField">
        <item name="android:textColorHint">@color/yp_black</item>
        <item name="android:backgroundTint">@color/white</item>
    </style>

    <style name="colorSwitch" parent="settingButtons">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="colorToolbar" parent="toolbar">
        <item name="titleTextColor">@color/white</item>
        <item name="backgroundTint">@color/yp_black</item>
    </style>

    <style name="colorToolbarWithArrow" parent="toolbar">
        <item name="titleTextColor">@color/white</item>
        <item name="backgroundTint">@color/yp_black</item>
        <item name="navigationIcon">@drawable/ic_arrow_back_24</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

</resources>